{
  "name": "ai-chat-platform",
  "version": "1.0.0",
  "description": "AI 角色扮演聊天平台 — 自定义角色、世界书、自定义 LLM/语音 API、社区分享",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "build:static": "VITE_STATIC=1 vite build --config client/vite.config.js",
    "build:single": "VITE_STATIC=1 VITE_SINGLEFILE=1 vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.18.0",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "puppeteer-core": "^25.1.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
