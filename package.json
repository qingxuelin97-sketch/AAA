{
  "name": "ai-chat-platform",
  "version": "1.0.0",
  "description": "AI 角色扮演聊天平台 — 自定义角色、世界书、自定义 LLM/语音 API、社区分享",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "build:static": "VITE_STATIC=1 vite build --config client/vite.config.js",
    "build:single": "VITE_STATIC=1 VITE_SINGLEFILE=1 vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "smoke": "node server/smoke.mjs",
    "reg-flow": "node server/reg-flow.mjs",
    "test:novels": "node server/novel-test.mjs",
    "test:novels:mock": "node server/novel-mock-test.mjs",
    "app:build": "npm run build:static && npx cap sync",
    "app:android": "npm run build:static && npx cap sync android && npx cap open android",
    "app:ios": "npm run build:static && npx cap sync ios && npx cap open ios",
    "app:build:remote": "npm run build && npx cap sync",
    "app:android:remote": "npm run build && npx cap sync android && npx cap open android",
    "app:ios:remote": "npm run build && npx cap sync ios && npx cap open ios",
    "app:add:android": "npx cap add android",
    "app:add:ios": "npx cap add ios",
    "test:sec": "node server/sec-test.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.18.0",
    "multer": "^2.2.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.9.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright-core": "^1.61.1",
    "puppeteer-core": "^25.1.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3"
  }
}