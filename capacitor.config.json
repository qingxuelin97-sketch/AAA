{
  "appId": "ai.huanyu.app",
  "appName": "幻域",
  "webDir": "client/dist",
  "backgroundColor": "#15120e",
  "server": { "androidScheme": "https" },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 700,
      "launchAutoHide": false,
      "backgroundColor": "#15120e",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": { "overlaysWebView": false },
    "Keyboard": { "resize": "native", "resizeOnFullScreen": true }
  }
}
