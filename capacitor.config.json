{
  "appId": "ai.huanyu.app",
  "appName": "幻域",
  "webDir": "client/dist",
  "backgroundColor": "#1b1733",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 700,
      "launchAutoHide": false,
      "backgroundColor": "#1b1733",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "LIGHT",
      "backgroundColor": "#eefbfd"
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true
    }
  }
}
